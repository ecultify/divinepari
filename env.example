# Environment Variables Required for Face Swap Application

# Segmind API Configuration
SEGMIND_API_KEY=your_segmind_api_key_here

# Server Configuration
PORT=5000

# Instructions:
# 1. For local development: Copy this file to .env and replace the values
# 2. For Netlify deployment: Add SEGMIND_API_KEY to Site Settings > Environment Variables
# 3. Get your API key from: https://www.segmind.com/

# Note: Never commit actual API keys to version control!

# Frontend Configuration (for client/.env)
REACT_APP_API_URL=http://localhost:5000/api 